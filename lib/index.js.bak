"use strict";

const chalk = require("chalk");

// Fungsi untuk menampilkan teks secara bertahap
const typeWriter = (text, delay, color = 'white', callback = null) => {
  let index = 0;
  const interval = setInterval(() => {
    process.stdout.write(chalk[color](text[index]));
    index++;
    if (index === text.length) {
      clearInterval(interval);
      console.log(); // New line
      if (callback) callback();
    }
  }, delay);
};

// Fungsi untuk menampilkan banner dengan efek bertahap
const showBanner = () => {
  const banner = [
    { text: "██╗  ██╗██╗  ██╗███████╗███████╗██╗  ██╗██╗   ██╗", color: 'cyan' },
    { text: "╚██╗██╔╝╚██╗██╔╝╚══███╔╝╚══███╔╝██║ ██╔╝╚██╗ ██╔╝", color: 'blue' },
    { text: " ╚███╔╝  ╚███╔╝   ███╔╝   ███╔╝ █████╔╝  ╚████╔╝ ", color: 'magenta' },
    { text: " ██╔██╗  ██╔██╗  ███╔╝   ███╔╝  ██╔═██╗   ╚██╔╝  ", color: 'green' },
    { text: "██╔╝ ██╗██╔╝ ██╗███████╗███████╗██║  ██╗   ██║   ", color: 'yellow' },
    { text: "╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚══════╝╚═╝  ╚═╝   ╚═╝   ", color: 'red' }
  ];

  let lineIndex = 0;
  
  const printNextLine = () => {
    if (lineIndex < banner.length) {
      const line = banner[lineIndex];
      console.log(chalk[line.color].bold(line.text));
      lineIndex++;
      setTimeout(printNextLine, 150); // Delay antar baris
    } else {
      // Setelah banner selesai, tampilkan info dengan efek
      setTimeout(showInfo, 300);
    }
  };
  
  printNextLine();
};

// Fungsi untuk menampilkan informasi dengan efek bertahap
const showInfo = () => {
  console.log(); // Empty line
  
  // Creator dengan efek berkedip
  const creatorText = "Creator : @rkyyzz";
  const creatorColors = ['cyan', 'blue', 'magenta', 'green', 'yellow', 'red'];
  let colorIndex = 0;
  
  const creatorInterval = setInterval(() => {
    process.stdout.write('\r' + chalk[creatorColors[colorIndex]].bold(creatorText));
    colorIndex = (colorIndex + 1) % creatorColors.length;
  }, 200);
  
  setTimeout(() => {
    clearInterval(creatorInterval);
    console.log('\n' + chalk.green.bold('━').repeat(50));
    
    // Note dengan efek typewriter
    const note = "Note : Thank You For Using My Baileys";
    typeWriter(note, 80, 'white', () => {
      console.log(chalk.green.bold('━').repeat(50));
      console.log(); // Empty line
      
      // Tampilan tambahan dengan gradien
      setTimeout(() => {
        console.log(chalk.cyan('⚡') + chalk.yellow(' RILZX7 PRESENTS ') + chalk.cyan('⚡'));
        console.log(chalk.magenta('『 BAILEYS WHATSAPP BOT 』'));
        console.log(chalk.green.bold('━').repeat(50));
        
        // Animasi loading selesai
        const loading = ['◴', '◷', '◶', '◵'];
        let loadIndex = 0;
        const loadInterval = setInterval(() => {
          process.stdout.write('\r' + chalk.yellow(`System Ready ${loading[loadIndex]}`));
          loadIndex = (loadIndex + 1) % loading.length;
        }, 100);
        
        setTimeout(() => {
          clearInterval(loadInterval);
          console.log('\r' + chalk.green('✓ System Ready!'));
          console.log(chalk.cyan('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'));
        }, 1500);
      }, 500);
    });
  }, 2000);
};

// Bersihkan console
console.clear();

// Tampilkan header dengan animasi
console.log(chalk.cyan('╔═══════════════════════════════════════════╗'));
console.log(chalk.cyan('║      BAILEYS WHATSAPP BOT INITIALIZING     ║'));
console.log(chalk.cyan('╚═══════════════════════════════════════════╝\n'));

// Mulai animasi loading
const dots = ['.  ', '.. ', '...', ' ..', '  .', '   '];
let dotIndex = 0;
const loadingInterval = setInterval(() => {
  process.stdout.write('\r' + chalk.yellow('Loading ') + chalk.white(dots[dotIndex]));
  dotIndex = (dotIndex + 1) % dots.length;
}, 200);

// Setelah loading selesai, tampilkan banner utama
setTimeout(() => {
  clearInterval(loadingInterval);
  console.clear();
  console.log(chalk.green.bold('✓ LOADING COMPLETE!\n'));
  
  setTimeout(() => {
    showBanner();
  }, 500);
}, 2500);

